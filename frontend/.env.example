# Copy to ".env" in this folder (Vite loads it automatically; do not commit .env).
# Firebase Console → Project settings → Your apps → Web app → SDK setup and configuration

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — needed for Google Analytics in the Firebase web SDK
VITE_FIREBASE_MEASUREMENT_ID=

# Optional — canonical base URL for blog SEO (no trailing slash), e.g. https://yourdomain.com
VITE_PUBLIC_SITE_URL=

# Optional — LinkedIn profile URL (if unset, a placeholder path is used — set this in production)
VITE_LINKEDIN_URL=

# Optional — EmailJS browser send (template should include {{from_name}}, {{from_email}}, {{subject}}, {{message}}, {{reply_to}})
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Optional — analytics & social preview (Step 10 polish)
# Plausible: your site hostname as added in Plausible (uses script.manual.js + SPA pageviews)
VITE_PLAUSIBLE_DOMAIN=
# Standalone Google Analytics 4 (only if you are NOT using VITE_FIREBASE_MEASUREMENT_ID)
VITE_GA_MEASUREMENT_ID=
# Open Graph / Twitter default image: absolute URL or path under public/, e.g. /og.png
VITE_OG_IMAGE_URL=
# Twitter/X handle for meta tags, with or without @
VITE_TWITTER_SITE=
